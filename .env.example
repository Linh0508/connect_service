# ============================================================
# B6 CORE BUSINESS - ENVIRONMENT TEMPLATE
# Copy this file to .env and update values
# ============================================================

# ============================================================
# SERVER CONFIGURATION
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=info

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_USER=b6_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=b6_core_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://b6_user:change_this_password@postgres:5432/b6_core_db
DATABASE_DISABLED=false
DATABASE_CONNECT_TIMEOUT=30

# ============================================================
# B3 - ACCESS GATE SERVICE (B6 gọi sang)
# ============================================================
ACCESS_GATE_URL=http://b3-access-gate:8001
ACCESS_GATE_API_KEY=
ACCESS_GATE_TIMEOUT=3.0
ACCESS_GATE_AUTO_DETECT=true

# ============================================================
# B4 - AI VISION SERVICE (B6 gọi sang)
# ============================================================
AI_VISION_URL=http://b6-ai-vision:9000
AI_VISION_AUTO_DETECT=true

# ============================================================
# B7 - NOTIFICATION SERVICE (B6 gọi sang)
# ============================================================
NOTIFICATION_URL=http://b7-notification:8002
NOTIFICATION_WEBHOOK_PATH=/webhook/alerts
NOTIFICATION_TIMEOUT=5.0
NOTIFICATION_AUTO_DETECT=true

# ============================================================
# B5 - ANALYTICS SERVICE (B6 gọi sang)
# ============================================================
ANALYTICS_URL=http://b5-analytics:8003
ANALYTICS_WEBHOOK_PATH=/webhook/decisions
ANALYTICS_TIMEOUT=5.0
ANALYTICS_AUTO_DETECT=true

# ============================================================
# SECURITY (JWT - thay đổi trong production)
# ============================================================
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================================
# BUSINESS RULES
# ============================================================
CACHE_TTL_SECONDS=300
IDEMPOTENCY_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=5000
RATE_LIMIT_WINDOW_SECONDS=60
DEFAULT_QUOTA_PER_DAY=5
RULE_ENGINE_LATENCY_THRESHOLD_MS=150

# ============================================================
# CONNECTION MANAGEMENT
# ============================================================
# Tự động kiểm tra kết nối đến các B khác
CONNECTION_CHECK_INTERVAL=30
CONNECTION_AUTO_DETECT=true