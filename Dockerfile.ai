# ============================================================
# AI Vision Mock Service for B6 Core Business
# ============================================================

FROM python:3.11-slim

# Create non-root user
RUN addgroup --system --gid 1001 aigroup && \
    adduser --system --uid 1001 --gid 1001 aiuser

# Install curl for healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies
COPY requirements.ai.txt .
RUN pip install --no-cache-dir -r requirements.ai.txt

# Copy application code
COPY src/ai_service/ ./src/ai_service/

# Create models directory
RUN mkdir -p /app/models && chown -R aiuser:aigroup /app

# Switch to non-root user
USER aiuser

EXPOSE 9000

# Health check with longer interval
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=5 \
    CMD curl -f http://localhost:9000/health || exit 1

CMD ["python", "-m", "uvicorn", "src.ai_service.main:app", "--host", "0.0.0.0", "--port", "9000"]
